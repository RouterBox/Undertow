# Undertow service config — copy this file to .env and fill in your values.
#
#   cp service/.env.example service/.env
#
# .env is gitignored. Never commit a populated copy.

# --- Neo4j (required) ---
# Pick any password. Whatever you put here must match the password the
# Neo4j Docker container was created with — see start.sh / INSTALL.md.
NEO4J_PASS=changeme

# Optional Neo4j connection overrides. Defaults shown.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j

# --- Anthropic (required) ---
# Used by Impulse, Gobble, Dreamer, Wonder, and the historical ingestor.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Gemini (required for vector search) ---
# Used by the embedding pipeline for semantic flash retrieval.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Prowler upstream (optional) ---
# Brave Search powers fast in-turn web lookups. Without this, Prowler's
# upstream path is silently skipped.
# https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# --- Prowler downstream (optional) ---
# Perplexity powers between-turn deep research that writes neurons.
# Without this, Prowler's downstream path is silently skipped.
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
